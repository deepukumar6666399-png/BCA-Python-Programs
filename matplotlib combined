import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# NumPy data
data = np.array([10, 20, 30, 40, 50])

# Pandas DataFrame
df = pd.DataFrame(data, columns=["Values"])

# Analysis
print("Mean:", df["Values"].mean())

# Plot
plt.plot(df["Values"])
plt.title("Data Analysis Graph")
plt.show()